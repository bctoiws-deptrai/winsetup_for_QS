<UserControl x:Class="BctWinsetup.Views.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="600">
    <UserControl.Resources>
        
        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#2D2D2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#121212" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="Hệ Thống Công Cụ Winsetup" 
                           Foreground="#FFFFFF" 
                           FontSize="24" 
                           FontWeight="SemiBold" 
                           FontFamily="Segoe UI"/>
                <TextBlock Text="Thông tin cấu hình chi tiết hệ thống và bảng tiện ích thiết lập." 
                           Foreground="#A0A0A0" 
                           FontSize="13" 
                           Margin="0,4,0,0" 
                           FontFamily="Segoe UI"/>
            </StackPanel>

            
            <Border Grid.Column="1" x:Name="BrdBadge" 
                    Background="#1E2E25" BorderBrush="#2D603A" BorderThickness="1" 
                    CornerRadius="14" Padding="12,6" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="ElpBadgeStatus" Width="8" Height="8" Fill="#2ECC71" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtPrivilege" Text="ADMINISTRATOR" 
                               Foreground="#2ECC71" FontSize="11" FontWeight="Bold" FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>
        </Grid>

        
        <Border Grid.Row="1" Background="#1A2535" BorderBrush="#2B3C58" BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="12" Height="12" Fill="#00A2ED" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Hãy thiết lập Định Danh Máy và Khôi Phục Driver khi vừa hoàn tất cài đặt lại Windows." 
                           Foreground="#00A2ED" 
                           FontSize="13" 
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI"/>
            </StackPanel>
        </Border>

        
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Thông tin cấu hình phần cứng" 
                       Foreground="#FFFFFF" 
                       FontSize="15" 
                       FontWeight="Medium" 
                       Margin="0,0,0,10" 
                       FontFamily="Segoe UI"/>

            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <UniformGrid Columns="2" Margin="0,0,-12,0">
                    
                    
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="HỆ ĐIỀU HÀNH" Foreground="#A0A0A0" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtOsVersion" Text="Loading..." Foreground="#00A2ED" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="TxtOsArchitecture" Text="64-bit Operating System" Foreground="#666666" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="TÊN MÁY &amp; TÀI KHOẢN" Foreground="#A0A0A0" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtMachineName" Text="Loading..." Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtUserName" Text="User" Foreground="#666666" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="BỘ VI XỬ LÝ (CPU)" Foreground="#A0A0A0" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtCpuName" Text="Loading..." Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="TxtCpuCores" Text="cores" Foreground="#666666" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="BỘ NHỚ TRONG (RAM)" Foreground="#A0A0A0" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtRamSize" Text="Loading..." Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="Tổng dung lượng RAM vật lý lắp đặt" Foreground="#666666" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="BO MẠCH CHỦ (MAINBOARD)" Foreground="#A0A0A0" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtMainboard" Text="Loading..." Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock Text="Thông tin nhà sản xuất và model máy" Foreground="#666666" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="CARD MÀN HÌNH (GPU)" Foreground="#A0A0A0" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtGpuName" Text="Loading..." Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock Text="Danh sách thiết bị đồ họa nhận diện" Foreground="#666666" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>

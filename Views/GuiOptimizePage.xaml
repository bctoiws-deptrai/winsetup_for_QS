<UserControl x:Class="BctWinsetup.Views.GuiOptimizePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="600">
    <UserControl.Resources>
        
        <Style TargetType="Button" x:Key="ModernButtonStyle">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0086F0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2D2D2D"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="OutlineButtonStyle" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="#444444" 
                                BorderThickness="1"
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252525"/>
                    <Setter Property="BorderBrush" Value="#666666"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1A1A1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        
        <Style TargetType="CheckBox" x:Key="OptionCheckBoxStyle">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#121212" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Tối Ưu Giao Diện Windows" 
                       Foreground="#FFFFFF" 
                       FontSize="22" 
                       FontWeight="SemiBold" 
                       FontFamily="Segoe UI"/>
            <TextBlock Text="Cấu hình nhanh các thiết lập tối ưu biểu tượng màn hình, thư mục ẩn và File Explorer." 
                       Foreground="#A0A0A0" 
                       FontSize="13" 
                       Margin="0,4,0,0" 
                       FontFamily="Segoe UI"/>
        </StackPanel>

        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
            <StackPanel>
                
                <Border BorderBrush="#252525" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="MÀN HÌNH CHÍNH (DESKTOP)" Foreground="#00A2ED" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                        <CheckBox x:Name="ChkAutoArrange" Style="{StaticResource OptionCheckBoxStyle}" IsChecked="True">
                            <StackPanel Margin="6,-2,0,0">
                                <TextBlock Text="Tự động sắp xếp biểu tượng Desktop (Auto Arrange)" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                <TextBlock Text="Giúp biểu tượng màn hình luôn được xếp thẳng hàng và ngăn nắp" Foreground="#888888" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>
                    </StackPanel>
                </Border>

                
                <Border BorderBrush="#252525" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="FILE EXPLORER &amp; TỆP TIN" Foreground="#00A2ED" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                        
                        <CheckBox x:Name="ChkLaunchTo" Style="{StaticResource OptionCheckBoxStyle}" IsChecked="True" Margin="0,6,0,12">
                            <StackPanel Margin="6,-2,0,0">
                                <TextBlock Text="Mặc định mở File Explorer vào 'This PC' (Thay vì Home/Quick Access)" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                <TextBlock Text="Hiển thị ngay các ổ đĩa cứng và thiết bị khi nhấn Win+E" Foreground="#888888" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <CheckBox x:Name="ChkShowHidden" Style="{StaticResource OptionCheckBoxStyle}" IsChecked="True" Margin="0,6,0,12">
                            <StackPanel Margin="6,-2,0,0">
                                <TextBlock Text="Hiển thị các tệp tin và thư mục ẩn (Show Hidden Files)" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                <TextBlock Text="Cho phép nhìn thấy các tệp tin hệ thống và tệp tin ẩn trên ổ đĩa" Foreground="#888888" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <CheckBox x:Name="ChkShowExtensions" Style="{StaticResource OptionCheckBoxStyle}" IsChecked="True">
                            <StackPanel Margin="6,-2,0,0">
                                <TextBlock Text="Hiển thị phần mở rộng của tên tệp tin (File Extensions)" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                <TextBlock Text="Hiển thị rõ đuôi tệp tin (ví dụ: .exe, .txt, .pdf) để quản lý và tránh phần mềm độc hại" Foreground="#888888" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>
                    </StackPanel>
                </Border>

                
                <StackPanel>
                    <TextBlock Text="CÀI ĐẶT HỆ THỐNG" Foreground="#00A2ED" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkRestartExplorer" Style="{StaticResource OptionCheckBoxStyle}" IsChecked="True">
                        <StackPanel Margin="6,-2,0,0">
                            <TextBlock Text="Tự động khởi động lại Windows Explorer để áp dụng ngay lập tức" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                            <TextBlock Text="Khởi chạy lại explorer.exe sau khi ghi registry để cập nhật giao diện mà không cần khởi động lại máy" Foreground="#888888" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </CheckBox>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <Grid Margin="0,0,0,6">
                <TextBlock x:Name="TxtStatus" Text="Sẵn sàng áp dụng tối ưu giao diện." 
                           Foreground="#A0A0A0" FontSize="13" FontFamily="Segoe UI"/>
                <TextBlock x:Name="TxtPercentage" Text="" 
                           Foreground="#00A2ED" FontSize="13" FontWeight="SemiBold" 
                           HorizontalAlignment="Right" FontFamily="Segoe UI"/>
            </Grid>
            <ProgressBar x:Name="ProgBar" Height="4" Background="#1E1E1E" Foreground="#0078D4" 
                         BorderThickness="0" Minimum="0" Maximum="100" Value="0"/>
        </StackPanel>

        
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Border Background="#1E1E1E" BorderBrush="#2D2D2D" BorderThickness="1" CornerRadius="4">
                <TextBox x:Name="TxtLog" 
                         Background="Transparent" 
                         Foreground="#A0A0A0" 
                         BorderThickness="0" 
                         Padding="12" 
                         FontFamily="Consolas" 
                         FontSize="12" 
                         IsReadOnly="True" 
                         VerticalScrollBarVisibility="Auto" 
                         AcceptsReturn="True" 
                         TextWrapping="Wrap"
                         Text="--- Nhật ký tối ưu giao diện ---&#x0a;Chờ lệnh từ người dùng..."/>
            </Border>
        </Grid>

        
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="BtnApply" 
                        Content="Áp dụng tối ưu" 
                        Style="{StaticResource ModernButtonStyle}" 
                        Padding="24,12" 
                        Click="BtnApply_Click"/>
                <Button x:Name="BtnReset" 
                        Content="Khôi phục mặc định" 
                        Style="{StaticResource OutlineButtonStyle}" 
                        Margin="12,0,0,0" 
                        Padding="16,12" 
                        Click="BtnReset_Click"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Chọn tất cả" Style="{StaticResource OutlineButtonStyle}" Click="BtnSelectAll_Click" Margin="0,0,8,0" Padding="12,8"/>
                <Button Content="Bỏ chọn tất cả" Style="{StaticResource OutlineButtonStyle}" Click="BtnDeselectAll_Click" Padding="12,8"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

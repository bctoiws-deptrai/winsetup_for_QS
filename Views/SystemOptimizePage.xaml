<UserControl x:Class="BctWinsetup.Views.SystemOptimizePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="700">
    <UserControl.Resources>
        
        <Style TargetType="Button" x:Key="ModernButtonStyle">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0086F0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2D2D2D"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        
        <Style TargetType="Button" x:Key="DangerButtonStyle" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#A80000"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C30000"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#7E0000"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2D2D2D"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        
        <Style TargetType="Button" x:Key="SuccessButtonStyle" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#107C41"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#108F4C"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0A5C30"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2D2D2D"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        
        <Style TargetType="Button" x:Key="OutlineButtonStyle" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="#444444" 
                                BorderThickness="1"
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252525"/>
                    <Setter Property="BorderBrush" Value="#666666"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1A1A1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        
        <Style TargetType="CheckBox" x:Key="OptionCheckBoxStyle">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#121212" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Tối Ưu Hiệu Năng &amp; Hệ Thống" 
                       Foreground="#FFFFFF" 
                       FontSize="22" 
                       FontWeight="SemiBold" 
                       FontFamily="Segoe UI"/>
            <TextBlock Text="Kích hoạt hiệu năng tối đa, tắt telemetry, Cortana, ứng dụng chạy ngầm và quản lý Windows Update/Defender." 
                       Foreground="#A0A0A0" 
                       FontSize="13" 
                       Margin="0,4,0,0" 
                       FontFamily="Segoe UI"/>
        </StackPanel>

        
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="TINH CHỈNH HIỆU NĂNG" Foreground="#00A2ED" FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                    
                    <Border BorderBrush="#252525" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                        <CheckBox x:Name="ChkUltimatePerf" Style="{StaticResource OptionCheckBoxStyle}" IsChecked="True">
                            <StackPanel Margin="6,-2,0,0">
                                <TextBlock Text="Kích hoạt Ultimate Performance (Hiệu năng tối đa)" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                <TextBlock Text="Mở khóa sơ đồ năng lượng hiệu năng cao nhất cho CPU và phần cứng" Foreground="#888888" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>
                    </Border>

                    
                    <Border BorderBrush="#252525" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                        <CheckBox x:Name="ChkDisableCortana" Style="{StaticResource OptionCheckBoxStyle}" IsChecked="True">
                            <StackPanel Margin="6,-2,0,0">
                                <TextBlock Text="Tắt Cortana &amp; Bing Search gợi ý" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                <TextBlock Text="Loại bỏ Cortana và kết quả tìm kiếm web từ Bing trong Start Menu" Foreground="#888888" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>
                    </Border>

                    
                    <Border BorderBrush="#252525" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                        <CheckBox x:Name="ChkDisableTelemetry" Style="{StaticResource OptionCheckBoxStyle}" IsChecked="True">
                            <StackPanel Margin="6,-2,0,0">
                                <TextBlock Text="Tắt Telemetry &amp; Dịch vụ Thu thập dữ liệu" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                <TextBlock Text="Vô hiệu hóa việc truyền dữ liệu chẩn đoán về Microsoft và tắt DiagTrack" Foreground="#888888" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>
                    </Border>

                    
                    <Border BorderBrush="#252525" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                        <CheckBox x:Name="ChkDisableBackgroundApps" Style="{StaticResource OptionCheckBoxStyle}" IsChecked="True">
                            <StackPanel Margin="6,-2,0,0">
                                <TextBlock Text="Tắt ứng dụng chạy ngầm (Background Apps)" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                <TextBlock Text="Ngăn chặn các ứng dụng Store tự chạy ngầm tiêu thụ tài nguyên RAM/CPU" Foreground="#888888" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>
                    </Border>

                    
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="BtnApplyTweaks" Content="Áp dụng tối ưu" Style="{StaticResource ModernButtonStyle}" Padding="20,10" Click="BtnApplyTweaks_Click"/>
                        <Button x:Name="BtnResetTweaks" Content="Khôi phục mặc định" Style="{StaticResource OutlineButtonStyle}" Margin="8,0,0,0" Padding="16,10" Click="BtnResetTweaks_Click"/>
                        <Button Content="Chọn tất cả" Style="{StaticResource OutlineButtonStyle}" Click="BtnSelectAll_Click" Margin="8,0,0,0"/>
                        <Button Content="Bỏ chọn tất cả" Style="{StaticResource OutlineButtonStyle}" Click="BtnDeselectAll_Click" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            
            <StackPanel Grid.Column="1">
                <TextBlock Text="ĐIỀU KHIỂN HỆ THỐNG" Foreground="#00A2ED" FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                
                <Border Background="#1E1E1E" BorderBrush="#2D2D2D" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Windows Update" Foreground="#FFFFFF" FontWeight="Bold" FontSize="14"/>
                        <Grid Margin="0,8,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Trạng thái:" Foreground="#888888" FontSize="12"/>
                            <TextBlock x:Name="TxtUpdateStatus" Text="Đang đọc..." Grid.Column="1" Foreground="#FFC107" FontSize="12" FontWeight="Bold" Margin="6,0,0,0" TextWrapping="Wrap"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnEnableUpdate" Content="Bật Update" Style="{StaticResource SuccessButtonStyle}" Margin="0,0,4,0" Padding="8" Click="BtnEnableUpdate_Click"/>
                            <Button x:Name="BtnDisableUpdate" Content="Tắt Update" Style="{StaticResource DangerButtonStyle}" Grid.Column="1" Margin="4,0,0,0" Padding="8" Click="BtnDisableUpdate_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                
                <Border Background="#1E1E1E" BorderBrush="#2D2D2D" BorderThickness="1" CornerRadius="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Windows Defender" Foreground="#FFFFFF" FontWeight="Bold" FontSize="14"/>
                        <Grid Margin="0,8,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Bảo vệ thời gian thực:" Foreground="#888888" FontSize="12"/>
                            <TextBlock x:Name="TxtDefenderStatus" Text="Đang đọc..." Grid.Column="1" Foreground="#FFC107" FontSize="12" FontWeight="Bold" Margin="6,0,0,0" TextWrapping="Wrap"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnEnableDefender" Content="Bật Defender" Style="{StaticResource SuccessButtonStyle}" Margin="0,0,4,0" Padding="8" Click="BtnEnableDefender_Click"/>
                            <Button x:Name="BtnDisableDefender" Content="Tắt Defender" Style="{StaticResource DangerButtonStyle}" Grid.Column="1" Margin="4,0,0,0" Padding="8" Click="BtnDisableDefender_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <Grid Margin="0,0,0,6">
                <TextBlock x:Name="TxtStatus" Text="Sẵn sàng thực thi tối ưu hệ thống." 
                           Foreground="#A0A0A0" FontSize="13" FontFamily="Segoe UI"/>
                <TextBlock x:Name="TxtPercentage" Text="" 
                           Foreground="#00A2ED" FontSize="13" FontWeight="SemiBold" 
                           HorizontalAlignment="Right" FontFamily="Segoe UI"/>
            </Grid>
            <ProgressBar x:Name="ProgBar" Height="4" Background="#1E1E1E" Foreground="#0078D4" 
                          BorderThickness="0" Minimum="0" Maximum="100" Value="0"/>
        </StackPanel>

        
        <Grid Grid.Row="3">
            <Border Background="#1E1E1E" BorderBrush="#2D2D2D" BorderThickness="1" CornerRadius="4">
                <TextBox x:Name="TxtLog" 
                         Background="Transparent" 
                         Foreground="#A0A0A0" 
                         BorderThickness="0" 
                         Padding="12" 
                         FontFamily="Consolas" 
                         FontSize="12" 
                         IsReadOnly="True" 
                         VerticalScrollBarVisibility="Auto" 
                         AcceptsReturn="True" 
                         TextWrapping="Wrap"
                         Text="--- Nhật ký tối ưu hệ thống ---&#x0a;Chờ lệnh từ người dùng..."/>
            </Border>
        </Grid>
    </Grid>
</UserControl>

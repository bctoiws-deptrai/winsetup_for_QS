<Window x:Class="BctWinsetup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BctWinsetup"
        mc:Ignorable="d"
        Title="BCT Winsetup Utility Suite v1.0" 
        Height="620" Width="920"
        WindowStartupLocation="CenterScreen"
        Background="#121212">

    <Window.Resources>
        
        <Style TargetType="RadioButton" x:Key="SidebarNavStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="SidebarNav"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border x:Name="Indicator" Grid.Column="0" Background="#00A2ED" Width="4" Height="20" CornerRadius="2" VerticalAlignment="Center" Opacity="0"/>
                                <ContentPresenter Grid.Column="1" Content="{TemplateBinding Content}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#222222"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1A222E"/>
                                <Setter TargetName="Indicator" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="#00A2ED"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        
        <Style TargetType="TextBlock" x:Key="SidebarLabelStyle">
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="20,16,20,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        
        <Style TargetType="Button" x:Key="SidebarPlaceholderStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="IsEnabled" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ColSidebar" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid x:Name="SidebarGrid" Grid.Column="0" Background="#181818" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="20,28,20,20">
                <TextBlock Text="BCT WINSETUP" 
                           Foreground="#FFFFFF" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           FontFamily="Segoe UI"/>
                <TextBlock Text="Hệ thống Tiện ích Tối ưu" 
                           Foreground="#666666" 
                           FontSize="11" 
                           Margin="0,4,0,0" 
                           FontFamily="Segoe UI"/>
                <Border Height="1" Background="#252525" Margin="0,16,0,0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <StackPanel x:Name="PnlCommonNav">
                        <RadioButton x:Name="RadBackToHome" 
                                     Content="◀  Quay Lại Trang Chủ" 
                                     Style="{StaticResource SidebarNavStyle}"
                                     Checked="RadBackToHome_Checked"/>
                        <Border Height="1" Background="#252525" Margin="20,10"/>
                    </StackPanel>

                    <StackPanel x:Name="PnlBeforeWinNav" Visibility="Collapsed">
                        <TextBlock Text="TRƯỚC KHI CÀI WIN" Style="{StaticResource SidebarLabelStyle}"/>
                        <RadioButton x:Name="RadDriverBackup" 
                                     Content="Sao Lưu Driver" 
                                     Style="{StaticResource SidebarNavStyle}"
                                     Checked="Navigation_Checked"/>
                        <RadioButton x:Name="RadDataBackup" 
                                     Content="Sao Lưu Dữ Liệu" 
                                     Style="{StaticResource SidebarNavStyle}"
                                     Checked="Navigation_Checked"/>
                    </StackPanel>

                    <StackPanel x:Name="PnlAfterWinNav" Visibility="Collapsed">
                        <TextBlock Text="SAU KHI CÀI WIN" Style="{StaticResource SidebarLabelStyle}"/>
                        <RadioButton x:Name="RadDriverRestore" 
                                     Content="Khôi Phục Driver" 
                                     Style="{StaticResource SidebarNavStyle}"
                                     Checked="Navigation_Checked"/>
                        <RadioButton x:Name="RadIdentity" 
                                     Content="Định Danh Máy" 
                                     Style="{StaticResource SidebarNavStyle}"
                                     Checked="Navigation_Checked"/>
                        <RadioButton x:Name="RadSoftwareInstall" 
                                     Content="Cài Phần Mềm" 
                                     Style="{StaticResource SidebarNavStyle}"
                                     Checked="Navigation_Checked"/>
                        <RadioButton x:Name="RadFontInstall" 
                                     Content="Cài Font Chữ" 
                                     Style="{StaticResource SidebarNavStyle}"
                                     Checked="Navigation_Checked"/>
                        <RadioButton x:Name="RadClearLogs" 
                                     Content="Xóa Log Hệ Thống" 
                                     Style="{StaticResource SidebarNavStyle}"
                                     Checked="Navigation_Checked"/>
                        <RadioButton x:Name="RadGuiOptimize" 
                                     Content="Tối Ưu Giao Diện" 
                                     Style="{StaticResource SidebarNavStyle}"
                                     Checked="Navigation_Checked"/>
                        <RadioButton x:Name="RadRunScript" 
                                     Content="Chạy Script Auto" 
                                     Style="{StaticResource SidebarNavStyle}"
                                     Checked="Navigation_Checked"/>
                    </StackPanel>

                    <StackPanel x:Name="PnlDeepBootNav" Visibility="Collapsed">
                        <TextBlock Text="DEEP-BOOT" Style="{StaticResource SidebarLabelStyle}"/>
                        <RadioButton x:Name="RadSystemOptimize" 
                                     Content="Tối Ưu Hệ Thống" 
                                     Style="{StaticResource SidebarNavStyle}"
                                     Checked="Navigation_Checked"/>
                        <RadioButton x:Name="RadDeepCleanup" 
                                     Content="Dọn Dẹp Nâng Cao" 
                                     Style="{StaticResource SidebarNavStyle}"
                                     Checked="Navigation_Checked"/>
                        <RadioButton x:Name="RadSuperOptimize" 
                                     Content="Siêu Tối Ưu" 
                                     Style="{StaticResource SidebarNavStyle}"
                                     Checked="Navigation_Checked"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Margin="20,10,20,20">
                <Border Height="1" Background="#252525" Margin="0,0,0,12"/>
                <TextBlock Text="Phiên bản 1.0.0" 
                           Foreground="#444444" 
                           FontSize="11" 
                           HorizontalAlignment="Center"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="Phát triển bởi BCT" 
                           Foreground="#555555" 
                           FontSize="10" 
                           Margin="0,2,0,0"
                           HorizontalAlignment="Center"
                           FontFamily="Segoe UI"/>
            </StackPanel>
        </Grid>

        <Border x:Name="SidebarBorder" Grid.Column="0" BorderBrush="#252525" BorderThickness="0,0,1,0" Visibility="Collapsed"/>

        <ContentControl Grid.Column="1" x:Name="MainContentArea" Focusable="False"/>
    </Grid>
</Window>
